{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "LibreHardwareService": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LibreHardwareService": {
    "useSharedMemory": true,
    "useHttp": false,
    "indexFormat": 1
  },
  "Settings": {
    "updateIntervalSeconds": 1,
    "memoryMapLimitKb": 1024,
    "Feature": {
      "featureEnableMemoryMapAllHardwareData": true
    }
  }
}
